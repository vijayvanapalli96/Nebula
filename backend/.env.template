APP_NAME="Interactive Cinematic Story Engine API"
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT="8000"

# Comma-separated list, or "*" for all origins in MVP mode.
CORS_ALLOW_ORIGINS="*"

GEMINI_API_KEY="your_google_ai_studio_api_key"
GEMINI_MODEL="gemini-2.5-flash"
IMAGEN_MODEL="imagen-4.0-generate-001"

# Optional: enable GCS uploads for generated images/videos.
GCS_BUCKET_NAME="nebula-story-images"
# Path to a GCP service account JSON key (needed for signed GCS URLs)
GCS_SA_KEY_PATH="sa-key.json"

# Optional: Firestore theme source.
# If FIREBASE_PROJECT_ID is empty, the API uses in-memory default themes.
FIREBASE_PROJECT_ID="disclosure-nlu"
FIREBASE_CREDENTIALS_PATH=""
FIREBASE_THEMES_COLLECTION="themes"
FIREBASE_STORIES_COLLECTION="stories"
FIREBASE_SCENES_SUBCOLLECTION="scenes"
FIREBASE_USERS_COLLECTION="users"
FIREBASE_USER_STORIES_SUBCOLLECTION="stories"
